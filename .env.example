# ============================================================
# THUMALIEN - Configuration Template
# Copiez ce fichier en .env et remplissez vos vraies valeurs
# NE JAMAIS COMMITTER LE FICHIER .env
# ============================================================

# --- Bluesky API ---
BLUESKY_HANDLE=votre-handle.bsky.social
BLUESKY_APP_PASSWORD=votre-mot-de-passe-app

# --- PostgreSQL (noms compatibles db_connector.py ET master) ---
DB_NAME=thumalien_db
DB_USER=thumalien_user
DB_PASSWORD=thumalien_password
DB_HOST=localhost
DB_PORT=5432

# Aliases pour compatibilité docker-compose + CLI master
POSTGRES_DB=thumalien_db
POSTGRES_USER=thumalien_user
POSTGRES_PASSWORD=thumalien_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
